# ---- Harness-injected at evaluation time (set locally for dev only; NEVER bake into image) ----
FIREWORKS_API_KEY=fw_xxx
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
ALLOWED_MODELS=accounts/fireworks/models/example-model-a,accounts/fireworks/models/example-model-b

# ---- verdict dev overrides (all optional; defaults live in src/core/settings.py) ----
# Backends: "mock" for the i3 laptop, "llama" / "fireworks" for real runs.
VERDICT_LOCAL_BACKEND=mock
VERDICT_REMOTE_BACKEND=mock

# Paths (container defaults are /input/tasks.json and /output/results.json)
VERDICT_INPUT=eval/mock_tasks/tasks.sample.json
VERDICT_OUTPUT=outputs/results.json
VERDICT_LEDGER=outputs/run.ledger.jsonl

# Local llama-server endpoint
VERDICT_LOCAL_BASE_URL=http://127.0.0.1:8080/v1

# Mock knobs: fraction of mock local generations deliberately corrupted (exercises
# the verify-fail -> repair -> escalate path). 0.0 = everything verifies.
VERDICT_MOCK_FAIL_RATE=0.0
VERDICT_MOCK_SEED=1337

# Wall-clock budget for the whole run, seconds (harness limit 600; keep a margin)
VERDICT_RUN_BUDGET_S=570
